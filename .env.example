# Application Settings
APP_NAME=AI Document Signer - FastAPI Engine
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
PORT=8000

# API Security
API_SECRET_KEY=your-super-secret-api-key-change-in-production
INTERNAL_API_KEY=internal-secret-key-for-nestjs-communication
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# NestJS Backend URL
NESTJS_URL=http://localhost:3000

# AWS S3 (for accessing documents)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=ai-document-signer-storage

# Redis (for caching OCR results)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1
CACHE_TTL=3600

# MongoDB (for storing processing results)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=ai_document_signer

# OCR Engine Selection
OCR_ENGINE=tesseract  # Options: tesseract, easyocr, paddleocr
OCR_LANGUAGE=eng
OCR_DPI=300

# ML Model Settings
USE_GPU=False
MODEL_CACHE_DIR=./models
CONFIDENCE_THRESHOLD=0.7

# Document Processing
MAX_FILE_SIZE_MB=50
SUPPORTED_FORMATS=pdf,png,jpg,jpeg,tiff
MAX_PAGES_PER_DOCUMENT=100

# Field Detection
ENABLE_NLP_FIELD_DETECTION=True
ENABLE_LAYOUT_ANALYSIS=True
FIELD_MATCHING_THRESHOLD=0.8

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/fastapi.log

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Worker Settings
MAX_WORKERS=4
ASYNC_PROCESSING=True
