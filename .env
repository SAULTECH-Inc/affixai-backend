# Application Settings
APP_NAME=AI Document Signer
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
PORT=8000

# API Security
API_SECRET_KEY=dev-api-secret-change-in-production
INTERNAL_API_KEY=dev-internal-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# JWT — required
JWT_SECRET=dev-jwt-secret-change-in-production-please-make-this-long
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-in-production-also-long
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=30

# Field-level encryption (AES-256-GCM) — required
ENCRYPTION_KEY=dev-encryption-key-change-in-production-must-be-stable
ENCRYPTION_ALGORITHM=aes-256-gcm

# Database (Postgres via Tortoise ORM)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_document_signer

# OAuth — Google (optional in dev; leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# SMTP / Email (optional in dev — failures are logged but non-fatal)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=False
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=AI Document Signer
FRONTEND_URL=http://localhost:5173

# Stripe (Phase 5)
STRIPE_SECRET_KEY=sk_test_51TiAvPDhRcvS3MGGVCzSEZ4spOEcmDJAZOsyVJHiFE7j1nleullRr0giGLycbi39NP6Sbm6BRMffXA2U553sGvvk0015ND8hxa
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=price_1TiBP3DhRcvS3MGGJutPlaUy
STRIPE_PRICE_ENTERPRISE=price_1TiBQpDhRcvS3MGGsPZfCnmO
FREE_TRIAL_DAYS=30
FREE_TIER_ENABLED=True
BILLING_CURRENCY=USD

# AWS S3 — required for document/signature uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=ai-document-signer-storage

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=1
CACHE_TTL=3600

# MongoDB (used by OCR services for storing results — optional)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=ai_document_signer

# OCR Engine Selection
OCR_ENGINE=tesseract
OCR_LANGUAGE=eng
OCR_DPI=300

# ML Model Settings
USE_GPU=False
MODEL_CACHE_DIR=./models
CONFIDENCE_THRESHOLD=0.7

# Document Processing
MAX_FILE_SIZE_MB=50
SUPPORTED_FORMATS=pdf,png,jpg,jpeg,tiff
MAX_PAGES_PER_DOCUMENT=100

# Field Detection
ENABLE_NLP_FIELD_DETECTION=True
ENABLE_LAYOUT_ANALYSIS=True
FIELD_MATCHING_THRESHOLD=0.8

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/fastapi.log

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Worker Settings
MAX_WORKERS=4
ASYNC_PROCESSING=True
SUPER_ADMIN_EMAILS=shadrach@openspace.finance
